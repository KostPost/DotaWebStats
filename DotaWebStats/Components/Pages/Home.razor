@page "/"
@using ModelClasses
@using DataBase
@using Microsoft.EntityFrameworkCore
@inject DotaWebStatsContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>Dota 2 Statistics</PageTitle>

<h1>Dota 2 Account Statistics</h1>

@* <div class="mb-3"> *@
@*    <button class="btn btn-primary" @onclick="AddAccount">Add New Account</button> *@
@* </div> *@

@* <button class="btn btn-primary" @onclick:preventDefault="AddAccount">Add New Account</button> *@
<a href="/add-account" class="btn btn-primary">Add New Account</a>

@if (accounts == null)
{
    <p>Loading...</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>User Name</th>
                <th>Current MMR</th>
                <th>MMR Remaining</th>
                <th>Regular Matches</th>
                <th>Double Matches</th>
                <th>Goal MMR</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var account in accounts)
            {
                <tr>
                    <td>@account.UserName</td>
                    <td>@account.CurrentMMR</td>
                    <td>@(account.GoalMMR - account.CurrentMMR)</td>
                    <td>@account.RegularMatches</td>
                    <td>@account.DoubleMatches</td>
                    <td>@account.GoalMMR</td>
                    <td>
                        <button class="btn btn-sm btn-info" @onclick="() => ViewDetails(account.Id)">View</button>
                        <button class="btn btn-sm btn-warning" @onclick="() => EditAccount(account.Id)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteAccount(account.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<UserAccount> accounts;

    protected override async Task OnInitializedAsync()
    {
        accounts = await DbContext.UserAccounts.ToListAsync();
    }

    private void AddAccount()
    {
        Console.WriteLine("AddAccount method called");
        NavigationManager.NavigateTo("/add-account");
    }

    private void ViewDetails(long id)
    {
        // Navigate to details page
    }

    private void EditAccount(long id)
    {   
        // Navigate to edit page
    }

    private async Task DeleteAccount(long id)
    {
        var account = await DbContext.UserAccounts.FindAsync(id);
        if (account != null)
        {
            DbContext.UserAccounts.Remove(account);
            await DbContext.SaveChangesAsync();
            accounts.Remove(account);
        }
    }
}