@page "/player/{Id}"
@using Services.Constants

<h1>Player Profile</h1>

@if (_player != null)
{
    <div class="player-profile">
        <img src="@_player.AvatarFull" alt="@_player.PersonaName's avatar"/>
        <h2>@_player.PersonaName</h2>
        <a href="@UrlConstants.SteamProfileUrl(_player.Steamid)" target="_blank" class="btn btn-primary">Steam Profile</a>
    </div>
}
else if (_isLoading)
{
    <p>Loading player data...</p>
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <p class="text-danger">Error: @_errorMessage</p>
}
else
{
    <p>Player not found or error loading data.</p>
}

