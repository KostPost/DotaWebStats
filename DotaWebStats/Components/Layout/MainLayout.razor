@using DotaWebStats.Components.Pages
@using ModelClasses
@using Services
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject SteamAuthService AuthService
@inject ISteamDataService SteamDataService

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            @if (!string.IsNullOrEmpty(SteamUserData?.PersonaName))
            {
                <div class="user-info">
                    <img src="@SteamUserData.AvatarFull" alt="User Avatar" class="user-avatar" />
                    <span class="username">@SteamUserData.PersonaName</span>
                </div>
            }
            else
            {
                <a href="/authentication" class="btn btn-primary">Sign in with Steam</a>
            }
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private SteamUserData.Player SteamUserData { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var steamIdParam = queryParams["openid.claimed_id"];

        if (!string.IsNullOrEmpty(steamIdParam))
        {
            var steamId = steamIdParam.Split('/').Last();
            SteamUserData = await SteamDataService.GetPlayerSummary(steamId);
        }
    }
}